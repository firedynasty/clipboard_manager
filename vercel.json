{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/qr", "destination": "/qr_bridge.html" },
    { "source": "/accumulator", "destination": "/clipboard_accumulator.html" },
    { "source": "/splitter", "destination": "/text_splitter.html" },
    { "source": "/images", "destination": "/clip_images.html" },
    { "source": "/screenshots", "destination": "/screenshots.html" },
    { "source": "/paths", "destination": "/paths.html" },
    { "source": "/parser", "destination": "/parser.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
